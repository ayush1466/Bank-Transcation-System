# ─── Database ───────────────────────────────────────────────
# MongoDB connection string. A replica set is required because
# transactions use multi-document sessions (mongoose transactions).
# MongoDB Atlas works out of the box.
MONGODB_CONNECTION_STRING=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/BankTransactionSystem?retryWrites=true&w=majority

# ─── Auth ───────────────────────────────────────────────────
# Secret used to sign JWTs. Use a long random string.
# e.g. node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=change_me_to_a_long_random_string

# ─── Email (Gmail OAuth2 via nodemailer) ────────────────────
# Google OAuth2 credentials for sending notification emails.
CLIENT_ID=your_google_oauth_client_id.apps.googleusercontent.com
CLIENT_SECRET=your_google_oauth_client_secret
REFRESH_TOKEN=your_google_oauth_refresh_token
EMAIL_USER=your_sender_address@gmail.com
